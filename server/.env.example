# Express server port
PORT=3000

# MongoDB Connection String (falls back to local connection if empty)
MONGODB_URI=mongodb://127.0.0.1:27017/blog-ai

# JWT Secret for Admin Session Tokens
JWT_SECRET=your_jwt_secret_key_here

# Admin Portal Credentials
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123

# Google Gemini API Key for AI generation features (optional, mock fallback is provided)
GEMINI_API_KEY=

# ImageKit API Credentials for image uploads (optional, local file fallback is provided)
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL_ENDPOINT=
